generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SourceType {
  WEB
  RSS
  VIDEO
  EXA
}

enum SourceRegion {
  DOMESTIC
  INTERNATIONAL
  UNKNOWN
}

enum SourceStatus {
  ACTIVE
  PAUSED
}

enum JobStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
}

enum PostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum VideoType {
  LOCAL
  EMBED
  LINK
}

enum CompilationKind {
  SINGLE_ARTICLE
  DAILY_DIGEST
  WEEKLY_ROUNDUP
}

model AdminUser {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  // 登出/改密时 +1，使已签发的 JWT 全部失效（JWT 无状态，本身无法吊销）
  tokenVersion Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model SiteSettings {
  id                       String   @id @default("site")
  name                     String   @default("拾贝 信息博客")
  description              String   @default("一个可以抓取、整理并发布信息的个人博客。")
  ownerName                String   @default("管理员")
  autoPublish              Boolean  @default(false)
  autoCurationEnabled      Boolean  @default(false)
  contentDisplayMode       String   @default("grid")
  contentLanguageMode      String   @default("default-language")
  defaultLanguage          String   @default("zh")
  defaultTheme             String   @default("apple")
  defaultFont              String   @default("sans-cjk")
  textOnlyMode             Boolean  @default(false)
  videosEnabled            Boolean  @default(false)
  maxStorageMb             Int      @default(2048)
  cleanupAfterDays         Int      @default(30)
  cleanupCustomEnabled     Boolean  @default(false)
  autoImageSearchEnabled   Boolean  @default(true)
  exaEnabled               Boolean  @default(false)
  exaApiKeyEnc             String?
  musicEnabledDefault      Boolean  @default(false)
  defaultMusicId           String?
  contentModelConfigId     String?
  assistantModelConfigId   String?
  writingModelConfigId     String?
  translationModelConfigId String?
  globalPromptPrefix       String   @default("") @db.Text
  defaultSettingsUI        String   @default("classic")
  syncMode                 String   @default("auto")
  syncBackendUrl           String   @default("")
  syncTokenEnc             String?
  syncIntervalMinutes      Int      @default(15)
  updatedAt                DateTime @updatedAt
}

model ModelConfig {
  id          String   @id @default(cuid())
  provider    String   @default("custom")
  name        String
  baseUrl     String
  model       String
  apiKeyEnc   String
  temperature Float    @default(0.3)
  maxTokens   Int      @default(1600)
  stream      Boolean  @default(false)
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isDefault])
}

model ContentStyle {
  id                 String         @id @default(cuid())
  name               String
  contentMode        String         @default("report")
  tone               String         @default("客观")
  length             String         @default("中")
  focus              String         @default("事实, 背景, 影响")
  outputStructure    String         @default("标题, 导语, 正文分章节叙述, 参考来源")
  customInstructions String         @db.Text
  isDefault          Boolean        @default(false)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  topics             ContentTopic[]
}

model Source {
  id                  String         @id @default(cuid())
  name                String
  url                 String
  type                SourceType
  status              SourceStatus   @default(ACTIVE)
  isDefault           Boolean        @default(false)
  isTemporary         Boolean        @default(false)
  region              SourceRegion   @default(UNKNOWN)
  popularity          Int            @default(0)
  popularityUpdatedAt DateTime?
  // 连续抓取失败计数：成功清零，达到阈值自动 PAUSED（见 worker recordSourceFailure）
  failStreak          Int            @default(0)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  modules             SourceModule[] @relation("SourceToModule")
  rawItems            RawItem[]
  jobs                FetchJob[]

  @@index([status, isDefault])
}

model SourceModule {
  id          String         @id @default(cuid())
  name        String         @unique
  slug        String         @unique
  description String?
  color       String         @default("#9f4f2f")
  iconKey     String?
  sortOrder   Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  sources     Source[]       @relation("SourceToModule")
  topics      ContentTopic[] @relation("ContentTopicToModule")
}

model FetchJob {
  id             String        @id @default(cuid())
  status         JobStatus     @default(QUEUED)
  sourceId       String?
  source         Source?       @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  sourceUrl      String
  sourceType     SourceType
  modelConfigId  String?
  contentStyleId String?
  contentTopicId String?
  contentTopic   ContentTopic? @relation(fields: [contentTopicId], references: [id], onDelete: SetNull)
  adminAiBatchId String?
  adminAiBatch   AdminAiBatch? @relation(fields: [adminAiBatchId], references: [id], onDelete: SetNull)
  error          String?       @db.Text
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  completedAt    DateTime?
  rawItems       RawItem[]

  @@index([status, updatedAt])
  @@index([createdAt])
  @@index([completedAt])
  @@index([sourceId])
  @@index([contentTopicId])
  @@index([adminAiBatchId])
}

// AI 管理员的一次计划执行 = 一个批次。既是进度聚合的锚点
// （批次进度 = 关联 FetchJob 的状态汇总），也是审计记录
// （谁在什么时候用什么需求让 AI 创建了哪些任务/周期主题）。
model AdminAiBatch {
  id        String     @id @default(cuid())
  request   String     @db.Text
  summary   String     @db.Text
  // 计划快照 JSON：{ tasks, recurring, createdTopics }，只作审计展示，不再反解执行。
  plan      String     @db.Text
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  jobs      FetchJob[]

  @@index([createdAt])
}

model RawItem {
  id          String    @id @default(cuid())
  title       String
  url         String
  content     String    @db.Text
  markdown    String    @db.Text
  sourceId    String?
  source      Source?   @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  fetchJobId  String?
  fetchJob    FetchJob? @relation(fields: [fetchJobId], references: [id], onDelete: SetNull)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  post        Post?

  @@index([createdAt])
  @@index([sourceId])
  @@index([fetchJobId])
}

model Post {
  id           String          @id @default(cuid())
  slug         String          @unique
  title        String
  titleEn      String?
  summary      String          @db.Text
  summaryEn    String?         @db.Text
  content      String          @db.Text
  contentEn    String?         @db.Text
  status       PostStatus      @default(DRAFT)
  kind         CompilationKind @default(SINGLE_ARTICLE)
  sourceUrl    String?
  sortOrder    Int             @default(0)
  translatedAt DateTime?
  rawItemId    String?         @unique
  rawItem      RawItem?        @relation(fields: [rawItemId], references: [id], onDelete: SetNull)
  videos       Video[]
  tags         Tag[]           @relation("PostTags")
  topics       ContentTopic[]  @relation("PostContentTopics")
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  publishedAt  DateTime?

  @@index([status, sortOrder, publishedAt])
  @@index([status, publishedAt])
  @@index([status, createdAt])
  @@index([updatedAt])
}

model Video {
  id             String       @id @default(cuid())
  title          String
  type           VideoType
  url            String
  coverUrl       String?
  summary        String       @db.Text
  displayMode    String       @default("embed")
  lastPlacement  String?      @db.VarChar(32)
  sortOrder      Int          @default(0)
  durationSec    Int?
  region         SourceRegion @default(UNKNOWN)
  sourcePlatform String?
  sourcePageUrl  String?
  localPath      String?
  fileSizeBytes  Int?
  downloadStatus String?      @db.VarChar(16)
  downloadError  String?      @db.Text
  attribution    String?      @db.Text
  postId         String?
  post           Post?        @relation(fields: [postId], references: [id], onDelete: SetNull)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([sortOrder, createdAt])
  @@index([createdAt])
  @@index([postId, sortOrder])
}

model Music {
  id            String   @id @default(cuid())
  title         String
  artist        String?
  filePath      String
  fileSizeBytes Int?
  durationSec   Int?
  isEnabled     Boolean  @default(true)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([isEnabled, sortOrder])
}

model Tag {
  id    String @id @default(cuid())
  name  String @unique
  posts Post[] @relation("PostTags")
}

model ContentTopic {
  id           String          @id @default(cuid())
  name         String          @unique
  slug         String          @unique
  description  String?
  scope        String          @default("all")
  keywords     String          @db.Text
  isEnabled    Boolean         @default(false)
  compileKind  CompilationKind @default(SINGLE_ARTICLE)
  depth        String          @default("long")
  articleCount Int             @default(1)
  useExa       Boolean         @default(true)
  modules      SourceModule[]  @relation("ContentTopicToModule")
  styleId      String?
  style        ContentStyle?   @relation(fields: [styleId], references: [id], onDelete: SetNull)
  schedule     AutoSchedule?
  posts        Post[]          @relation("PostContentTopics")
  fetchJobs    FetchJob[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([isEnabled, createdAt])
  @@index([styleId])
}

model AutoSchedule {
  id         String       @id @default(cuid())
  topicId    String       @unique
  topic      ContentTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  cron       String
  isEnabled  Boolean      @default(true)
  lastRunAt  DateTime?
  nextRunAt  DateTime?
  bullJobKey String?      @unique
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@index([isEnabled, nextRunAt])
}

// ============ 共创工作室（读者访谈式创作） ============

enum CreationMode {
  VOICE_FIRST // 读者的话为主：AI 只补结构和连接
  AI_FIRST // AI 的话为主：读者回答作为素材
}

enum CreationDepth {
  SHORT // 3 个问题 → 短评
  FULL // 8-10 个问题 → 完整文章
}

enum CreationStatus {
  INTERVIEWING
  DRAFT
  SHARED
}

model MemberUser {
  id           String         @id @default(cuid())
  email        String         @unique
  passwordHash String
  displayName  String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  works        CreativeWork[]
}

// 题材即评分标尺：选题材的同时确定评分维度、权重与公开阈值。
// dimensions 是 JSON 数组 [{ key, label, weight, hint }]，权重和为 1。
model CreationGenre {
  id          String         @id @default(cuid())
  slug        String         @unique
  name        String
  description String         @default("")
  dimensions  String         @db.Text
  threshold   Int            @default(70)
  sortOrder   Int            @default(0)
  isEnabled   Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  works       CreativeWork[]
}

// 读者与 AI 共创的作品。默认私有：只有 status=SHARED 才对外可见。
// 匿名创作用 anonId(cookie) 标识所有权、clientIp 做未登录生成配额；
// scoredHash 记录评分时的内容哈希，发布时哈希不一致必须重新评分。
model CreativeWork {
  id               String         @id @default(cuid())
  slug             String?        @unique
  ownerId          String?
  owner            MemberUser?    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  anonId           String?
  clientIp         String?
  genreId          String
  genre            CreationGenre  @relation(fields: [genreId], references: [id], onDelete: Restrict)
  mode             CreationMode
  depth            CreationDepth
  status           CreationStatus @default(INTERVIEWING)
  topic            String
  interview        String         @default("[]") @db.Text
  pendingQuestion  String?        @db.Text
  title            String         @default("")
  summary          String         @default("") @db.Text
  content          String         @default("") @db.Text
  draftGeneratedAt DateTime?
  score            Float?
  scoreDetail      String?        @db.Text
  scoredAt         DateTime?
  scoredHash       String?
  publishedAt      DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([status, publishedAt])
  @@index([ownerId, updatedAt])
  @@index([anonId, updatedAt])
  @@index([clientIp, draftGeneratedAt])
  @@index([genreId])
}

// Frontend / backend / full 间的同步状态。仅一行（id="sync"）。
//   - lastImportedAt:frontend 上次成功 import 的时间（或 full 自测时）
//   - lastImportedPostCount:上次 import 影响行数
//   - lastExportedAt:backend 上次成功 export 的时间
//   - lastError:最近一次失败的错误串（成功后清空）
model SyncState {
  id                    String    @id @default("sync")
  lastImportedAt        DateTime?
  lastImportedPostCount Int       @default(0)
  lastExportedAt        DateTime?
  lastError             String?   @db.Text
  updatedAt             DateTime  @updatedAt
}
