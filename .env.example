DATABASE_URL="postgresql://shibei:shibei@postgres:5432/shibei_blog?schema=public"
REDIS_URL="redis://redis:6379"
AUTH_SECRET="replace-with-a-long-random-secret"
ENCRYPTION_KEY="replace-with-32-byte-hex-or-strong-random-string"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Initial seed admin. Change after first login in Settings.
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-me-now"

# ============================================================================
# 部署形态（拆分前端 / 后端 / 完整版）
# ============================================================================
# APP_MODE 决定本进程的角色：
#   full     — 单机自给自足（默认；与历史行为一致）
#   frontend — 只展示文章/视频，AI 接口转发到 backend，文章从 backend 同步
#   backend  — 只做抓取/总结/调度，把文章通过 /api/admin/sync/export 暴露
APP_MODE="full"

# 仅 frontend/full 拉取时有意义。也可以启动后在 /admin/sync 网页端修改。
# auto = 定时拉取 backend；manual = 仅支持手动上传 ZIP/手动同步
SYNC_MODE="auto"

# 自动拉取间隔（分钟）。frontend 模式下 sync-worker 会按这个间隔执行同步。
SYNC_INTERVAL_MINUTES="15"

# frontend 模式连接 backend 的 HTTP 入口；推荐在 /admin/sync 网页端填写。
BACKEND_API_URL=""

# frontend 与 backend 共享的鉴权密钥；推荐在 /admin/sync 网页端填写。
# 用于：
#   1) frontend 拉 /api/admin/sync/export
#   2) frontend AI 代理转发到 backend /api/public/*
# 两端必须填同一串；自己生成一个长随机字符串即可。
SYNC_TOKEN=""
