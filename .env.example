# =============================================================================
# 拾贝 ShiBei — 环境变量样板
# =============================================================================
# 1) 复制为 .env：cp .env.example .env
# 2) 至少修改 AUTH_SECRET / ENCRYPTION_KEY / ADMIN_PASSWORD；非本机访问还要改 PUBLIC_URL
# 3) 其余可启动后在 /admin/sync 与 /admin/settings 网页端保存
# =============================================================================

# --- 数据库与缓存（compose 默认值，单机部署不要改）-----------------------------
DATABASE_URL="postgresql://shibei:shibei@postgres:5432/shibei_blog?schema=public"
REDIS_URL="redis://redis:6379"

# --- 安全密钥（必须改！长随机字符串，建议 openssl rand -hex 32 生成）-----------
AUTH_SECRET="replace-with-a-long-random-secret"
ENCRYPTION_KEY="replace-with-32-byte-hex-or-strong-random-string"

# --- HTTP 应用入口与公开 URL ------------------------------------------
# 默认与大多数自托管应用一样：拾贝只提供 HTTP，不占用 80/443，
# 不签发证书。启动后可直接访问 http://<服务器IP>:3000。
APP_BIND_IP="0.0.0.0"
APP_PORT="3000"

# 浏览器实际访问的唯一公开起源（不要带末尾斜杠或路径）。
# 这是运行时配置，换域名后修改 .env 并重启 app 即可，无需重建镜像。
#
# 直接 HTTP（仅建议本机/受信 LAN）：
PUBLIC_URL="http://localhost:3000"
# 公网域名（由用户自己的 Nginx/Caddy/Traefik 终止 TLS）：
# PUBLIC_URL="https://blog.example.com"
# APP_BIND_IP="127.0.0.1"

# 应用与客户端之间的固定可信反代层数。端口可被客户端直连时必须为 0；
# 同机单层 Nginx/Caddy/Traefik 且 APP_BIND_IP=127.0.0.1 时设为 1。
TRUST_PROXY_HOPS="0"

# --- 管理员账号（每次容器启动 seed 都会用这里的值同步数据库）---------------
# .env 是密码的权威来源：改了这里 + 重启容器，新密码立刻生效；如果你在
# /admin/settings 用 UI 改密码，记得回头同步改这里，否则下次重启会回滚并吊销旧会话。
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-me-now"

# 会员默认仅允许管理员邀请码注册。只有明确需要开放邮箱注册时才设为 true。
ALLOW_PUBLIC_MEMBER_REGISTRATION="false"

# =============================================================================
# 部署形态（拆分前端 / 后端 / 完整版）
# =============================================================================
# APP_MODE 决定本进程的角色：
#   full     — 单机自给自足（默认；与历史行为一致）
#   frontend — 只展示文章/视频，AI 接口转发到 backend，文章从 backend 同步
#   backend  — 只做抓取/总结/调度，把文章通过 /api/admin/sync/export 暴露
APP_MODE="full"

# 仅 frontend/full 拉取时有意义。也可以启动后在 /admin/sync 网页端修改。
# auto = 定时拉取 backend；manual = 仅支持手动上传 ZIP/手动同步
SYNC_MODE="auto"

# 自动拉取间隔（分钟）。frontend 模式下 sync-worker 会按这个间隔执行同步。
SYNC_INTERVAL_MINUTES="15"

# frontend 连接 backend 的入口；推荐在 /admin/sync 网页端填写。
# 该连接会携带 SYNC_TOKEN 并代理 AI 请求：跨公网必须使用 HTTPS，
# 不得使用 http://公网IP:3000。受防火墙保护的 LAN/VPN 可填私网 IP，
# Docker 网络可填单标签服务名；SSH 隧道可填 http://127.0.0.1:3300。
BACKEND_API_URL=""

# frontend 与 backend 共享的鉴权密钥；推荐在 /admin/sync 网页端填写。
# 用于：
#   1) frontend 拉 /api/admin/sync/export
#   2) frontend AI 代理转发到 backend /api/public/*
#   3) backend 模式下校验所有 /api/public/* 调用都带此密钥；
#      没有这层校验，把 backend 暴露到公网等于把 AI Key 接到了开放代理。
# 两端必须填同一串；自己生成一个长随机字符串：openssl rand -hex 32
SYNC_TOKEN=""

# =============================================================================
# 可选：worker 并发数（仅 backend / full 模式生效）
# =============================================================================
# 默认 1，低内存机器留 1。2 核 4G 可以提到 2，依此类推。
# FETCH_WORKER_CONCURRENCY="1"
# RESEARCH_WORKER_CONCURRENCY="1"
# AUDIENCE_WORKER_CONCURRENCY="1"
# SCHEDULE_WORKER_CONCURRENCY="1"

# =============================================================================
# 可选：AI 请求超时上限（毫秒）
# =============================================================================
# 默认 reasoning 模型 600s、其他 240s。极慢网络/超长 prompt 时再调高。
# AI_REQUEST_TIMEOUT_MS="900000"

# =============================================================================
# 可选：公开 AI 接口每日总额度（防止公网流量打穿模型账单）
# =============================================================================
# AI_ASSISTANT_DAILY_LIMIT="300"
# AI_WRITING_DAILY_LIMIT="200"
# AI_TRANSLATION_DAILY_LIMIT="120"
# 共创工作室（访谈提问/成稿/评分）每日 AI 调用总额度，默认 300
# AI_CREATION_DAILY_LIMIT="300"

# =============================================================================
# 可选：网页端一键更新（三种形态通用）
# =============================================================================
# 由 compose 里的 updater 伴车容器执行「git 拉取 → 重建镜像 → 滚动重启」，
# 管理后台左上角弹窗与 /admin/update 页面即可完成更新，无需 SSH。
#
# app ↔ updater 之间的鉴权 token：留空时自动复用上面的 AUTH_SECRET，通常不用填。
# UPDATER_TOKEN=""
#
# updater 未运行时的降级检查走 GitHub API，用这两项定位仓库（fork 部署请改）。
# UPDATE_REPO="125639/ShiBei"
# UPDATE_BRANCH="main"
