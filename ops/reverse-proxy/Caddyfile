# Replace blog.example.com before loading this file.
# Caddy obtains and renews the public certificate automatically.

blog.example.com {
	request_body {
		# Leaves room for multipart overhead around the app's ZIP import limit (512 MB on full/backend; a frontend deployment defaults to 64 MB unless SYNC_MAX_ZIP_MB is raised).
		max_size 600MB
	}

	reverse_proxy 127.0.0.1:3000 {
		header_up Host {host}
		transport http {
			read_timeout 15m
			write_timeout 15m
		}
	}
}
