DATABASE_URL="postgresql://shibei:shibei@postgres:5432/shibei_blog?schema=public"
REDIS_URL="redis://redis:6379"
AUTH_SECRET="replace-with-a-long-random-secret"
ENCRYPTION_KEY="replace-with-32-byte-hex-or-strong-random-string"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Initial seed admin. Change after first login in Settings.
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-me-now"

# This directory is the backend app. docker-compose.yml forces APP_MODE=backend.
# Shared sync token can be configured later in /admin/sync; this env value is an optional fallback.
SYNC_TOKEN=""

# Worker defaults for low-memory VPS. Increase only if the server has enough CPU/RAM.
FETCH_WORKER_CONCURRENCY="1"
RESEARCH_WORKER_CONCURRENCY="1"
AUDIENCE_WORKER_CONCURRENCY="1"
SCHEDULE_WORKER_CONCURRENCY="1"
