{
  "name": "shibei-blog",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build --webpack",
    "start": "node scripts/trusted-next-server.mjs",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "bash tests/run-all.sh",
    "check": "npm run lint && npm run typecheck",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "repair:article-images": "tsx scripts/repair-article-images.ts",
    "repair:post-videos": "tsx scripts/redistribute-post-videos.ts",
    "repair:post-i18n": "tsx scripts/backfill-post-i18n.ts",
    "repair:post-topics": "tsx scripts/backfill-post-topics.ts",
    "repair:trusted-evidence": "tsx scripts/backfill-trusted-evidence-manifests.ts",
    "worker": "tsx src/worker/index.ts",
    "sync-worker": "tsx src/sync-worker/index.ts"
  },
  "overrides": {
    "esbuild": "0.28.1",
    "postcss": "8.5.10",
    "undici": "$undici"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@floating-ui/dom": "^1.7.6",
    "@fontsource-variable/noto-sans-sc": "^5.2.10",
    "@prisma/client": "^5.22.0",
    "@tiptap/core": "^3.27.3",
    "@tiptap/extensions": "^3.27.3",
    "@tiptap/pm": "^3.27.3",
    "@tiptap/react": "^3.27.3",
    "@tiptap/starter-kit": "^3.27.3",
    "@tiptap/suggestion": "^3.27.3",
    "adm-zip": "^0.6.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.34.3",
    "feedparser": "^2.2.10",
    "ioredis": "^5.4.2",
    "isomorphic-dompurify": "^3.18.0",
    "jose": "^5.9.6",
    "marked": "^18.0.3",
    "next": "16.2.10",
    "playwright": "^1.61.1",
    "prisma": "^5.22.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tiptap-markdown": "^0.9.0",
    "turndown": "^7.2.0",
    "undici": "^7.28.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/bcryptjs": "^2.4.6",
    "@types/feedparser": "^2.2.8",
    "@types/node": "^22.9.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/turndown": "^5.0.5",
    "eslint": "^9.15.0",
    "eslint-config-next": "16.2.10",
    "tsx": "^4.19.2",
    "typescript": "5.9.3"
  }
}
