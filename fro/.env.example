DATABASE_URL="postgresql://shibei:shibei@postgres:5432/shibei_blog?schema=public"
AUTH_SECRET="replace-with-a-long-random-secret"
ENCRYPTION_KEY="replace-with-32-byte-hex-or-strong-random-string"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Initial seed admin. Change after first login in Settings.
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-me-now"

# This directory is the frontend app. docker-compose.yml forces APP_MODE=frontend.
# Backend URL, shared sync token, sync mode and interval can be configured later
# in /admin/sync. These env values remain optional fallbacks.
SYNC_MODE="auto"
SYNC_INTERVAL_MINUTES="15"
BACKEND_API_URL=""
SYNC_TOKEN=""
